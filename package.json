{
  "name": "lint-to-the-future-eslint",
  "version": "3.3.0",
  "repository": "https://github.com/mansona/lint-to-the-future-eslint",
  "license": "MIT",
  "type": "module",
  "main": "main.mjs",
  "scripts": {
    "format": "prettier . --cache --write",
    "lint": "concurrently \"npm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:fix": "concurrently \"npm:lint:*:fix\" --names \"fix:\" --prefixColors auto && npm run format",
    "lint:format": "prettier . --cache --check",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "test": "vitest test",
    "test-watch": "npm run test -- -w --reporter min"
  },
  "dependencies": {
    "globby": "^16.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "eslint-legacy": "npm:eslint@^8.0.0",
    "eslint-plugin-svelte": "^3.14.0",
    "execa": "^9.5.2",
    "find-up": "^6.3.0",
    "fixturify-project": "^7.1.2",
    "globals": "^15.14.0",
    "lint-to-the-future": "^2.6.2",
    "lint-to-the-future-eslint": "file:.",
    "pkg-up": "^4.0.0",
    "prettier": "^3.9.4",
    "release-plan": "^0.13.1",
    "svelte": "^5.49.2",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "eslint": "^6.0.0 || ^7.0.0 || ^8.0.0 || ^9.0.0 || ^10.0.0",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.2.1+sha512.398035c7bd696d0ba0b10a688ed558285329d27ea994804a52bad9167d8e3a72bcb993f9699585d3ca25779ac64949ef422757a6c31102c12ab932e5cbe5cc92",
  "engines": {
    "node": "20.* || 22.* || 24.* || >= 26.*"
  },
  "@authmaker/generator-express:version": "3.2.6"
}
